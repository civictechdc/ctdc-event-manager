{
  "name": "dc-tech-event-manager",
  "version": "1.0.0",
  "type": "module",
  "description": "CLI tool for creating and publishing events to Luma and Meetup.com platforms",
  "main": "dist/index.js",
  "bin": {
    "event-publisher": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run tsx src/index.ts",
    "dev:node": "tsx src/index.ts",
    "build": "bun run tsc",
    "start": "bun run dist/index.js",
    "start:node": "node dist/index.js",
    "test": "bun run vitest run",
    "test:watch": "bun run vitest",
    "test:ui": "bun run vitest --ui",
    "test:coverage": "bun run vitest run --coverage",
    "lint": "bun run eslint src tests",
    "typecheck": "bun run tsc --noEmit",
    "clean": "rm -rf dist",
    "verify:node-runtime": "bun run build && node dist/index.js --help",
    "docker:build": "docker build -f docker/Dockerfile -t event-publisher .",
    "docker:run": "docker run --env-file .env event-publisher",
    "docker:dev": "docker-compose -f docker/docker-compose.yml up"
  },
  "keywords": [
    "cli",
    "event",
    "luma",
    "meetup",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "date-fns": "^3.0.0",
    "dotenv": "^16.3.1",
    "handlebars": "^4.7.8",
    "inquirer": "^9.2.12",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/ui": "^1.0.4",
    "eslint": "^8.56.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=24.18.0 <24.19.0"
  }
}
